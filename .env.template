# Server-only direct connection to the macro Postgres database.
# Use a read-only application user with access limited to the `serving` schema.
PG_HOST=
PG_PORT=5432
PG_DATABASE=macro
PG_USER=
PG_PASSWORD=
PG_URL=postgresql://${PG_USER}:${PG_PASSWORD}@${PG_HOST}:${PG_PORT}/${PG_DATABASE}?sslmode=require

# Optional: override the semantic read surface if the database does not default
# to the `serving` layer described in `.agent/SPEC.md`.
MACRO_DB_SCHEMA=serving

# Optional: public app URL for absolute links, export metadata, and callbacks.
# For local development, keep this at the default Next.js dev URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000
